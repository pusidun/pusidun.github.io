---
export interface Props {
  href: string;
  label: string;
  subtitle?: string;
  index: number;
}
const { href, label, subtitle = '', index } = Astro.props;
const delay = `${100 + index * 80}ms`;
---
<a
  href={href}
  class="group relative block"
  style={`animation-delay: ${delay}`}
  data-menu-button
>
  <div
    class="relative flex items-center gap-4 bg-p5-white text-p5-black p5-clip-button px-7 sm:px-8 py-3 sm:py-4 transition-all duration-200 group-hover:bg-p5-yellow group-hover:translate-x-2 group-hover:-translate-y-1"
  >
    <span class="p5-menu-font p5-menu-wave text-2xl sm:text-3xl">{label}</span>
    {subtitle && (
      <span class="text-[10px] sm:text-xs font-black tracking-[0.2em] text-p5-red/70 ml-auto p5-menu-font">
        {subtitle}
      </span>
    )}
    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-p5-red font-black text-xl opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all">
      ▶
    </span>
  </div>
  <div
    class="absolute -bottom-2 left-3 -right-3 h-full bg-p5-red p5-clip-button -z-10 transition-transform group-hover:translate-x-1 group-hover:translate-y-1"
    aria-hidden="true"
  ></div>
</a>

<style>
  [data-menu-button] {
    opacity: 0;
    animation: slideInLeft 500ms cubic-bezier(0.5, 0, 0.2, 1) forwards;
  }
  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-60px) skewX(-8deg);
    }
    to {
      opacity: 1;
      transform: translateX(0) skewX(0);
    }
  }
</style>
