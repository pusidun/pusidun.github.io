---
export interface Props {
  numeral: string;
  name: string;
  subtitle: string;
  href: string;
  index: number;
  icon: 'fool' | 'magician' | 'emperor' | 'chariot';
}
const { numeral, name, subtitle, href, index, icon } = Astro.props;
---
<a
  href={href}
  class="arcana-card"
  data-arcana-card
  data-idx={index}
  aria-label={`${name} — ${subtitle}`}
>
  <div class="arcana-inner">
    <!-- Front (visible side: tarot face) -->
    <div class="face front">
      <div class="frame">
        <!-- Top numeral -->
        <div class="numeral-top">{numeral}</div>

        <!-- Center symbol -->
        <div class="symbol-wrap">
          <svg viewBox="0 0 100 100" aria-hidden="true">
            <!-- ornate frame -->
            <rect x="6" y="6" width="88" height="88" fill="none" stroke="#FFD400" stroke-width="1.5" />
            <rect x="10" y="10" width="80" height="80" fill="none" stroke="#FFD400" stroke-width="0.6" stroke-dasharray="2 2" />

            {icon === 'fool' && (
              <>
                <!-- The Fool: sun + small figure on cliff edge -->
                <circle cx="50" cy="34" r="14" fill="#FFD400" />
                <g stroke="#FFD400" stroke-width="2" stroke-linecap="round">
                  <line x1="50" y1="14" x2="50" y2="8" />
                  <line x1="50" y1="60" x2="50" y2="54" />
                  <line x1="30" y1="34" x2="24" y2="34" />
                  <line x1="76" y1="34" x2="70" y2="34" />
                  <line x1="36" y1="20" x2="32" y2="16" />
                  <line x1="64" y1="20" x2="68" y2="16" />
                  <line x1="36" y1="48" x2="32" y2="52" />
                  <line x1="64" y1="48" x2="68" y2="52" />
                </g>
                <!-- figure -->
                <circle cx="50" cy="68" r="4" fill="#F5F1E8" />
                <path d="M50 72 L50 84 L44 92 M50 84 L56 92" stroke="#F5F1E8" stroke-width="2.5" fill="none" stroke-linecap="round" />
              </>
            )}

            {icon === 'magician' && (
              <>
                <!-- The Magician: infinity + wand -->
                <path
                  d="M28 38 Q28 28, 38 28 Q48 28, 50 38 Q52 48, 62 48 Q72 48, 72 38 Q72 28, 62 28 Q52 28, 50 38 Q48 48, 38 48 Q28 48, 28 38 Z"
                  fill="none" stroke="#FFD400" stroke-width="2.5"
                />
                <!-- wand -->
                <line x1="50" y1="56" x2="50" y2="86" stroke="#F5F1E8" stroke-width="3" stroke-linecap="round" />
                <circle cx="50" cy="56" r="3" fill="#E60012" />
                <circle cx="50" cy="86" r="3" fill="#E60012" />
              </>
            )}

            {icon === 'emperor' && (
              <>
                <!-- The Emperor: throne / crown -->
                <path d="M30 35 L30 25 L38 30 L42 20 L50 28 L58 20 L62 30 L70 25 L70 35 Z"
                  fill="#FFD400" stroke="#F5F1E8" stroke-width="1.5" />
                <rect x="32" y="40" width="36" height="40" fill="none" stroke="#F5F1E8" stroke-width="2.5" />
                <rect x="38" y="46" width="24" height="6" fill="#E60012" />
                <line x1="50" y1="40" x2="50" y2="80" stroke="#F5F1E8" stroke-width="1.5" />
              </>
            )}

            {icon === 'chariot' && (
              <>
                <!-- The Chariot: wheel with rays -->
                <circle cx="50" cy="50" r="22" fill="none" stroke="#FFD400" stroke-width="2.5" />
                <circle cx="50" cy="50" r="6" fill="#E60012" />
                <g stroke="#F5F1E8" stroke-width="2" stroke-linecap="round">
                  <line x1="50" y1="28" x2="50" y2="72" />
                  <line x1="28" y1="50" x2="72" y2="50" />
                  <line x1="34" y1="34" x2="66" y2="66" />
                  <line x1="66" y1="34" x2="34" y2="66" />
                </g>
                <!-- star above -->
                <polygon points="50,12 52,18 58,18 53,22 55,28 50,24 45,28 47,22 42,18 48,18" fill="#FFD400" />
              </>
            )}
          </svg>
        </div>

        <!-- Card name -->
        <div class="name">{name}</div>

        <!-- Bottom numeral mirrored -->
        <div class="numeral-bottom">{numeral}</div>
      </div>
    </div>
  </div>

  <!-- Footer label (always visible below) -->
  <div class="footer">
    <span class="dest">→ {subtitle}</span>
  </div>
</a>

<style>
  .arcana-card {
    position: relative;
    display: block;
    aspect-ratio: 2 / 3;
    width: 100%;
    max-width: 200px;
    perspective: 1200px;
    will-change: transform, opacity;
  }
  @media (max-width: 1023px) {
    .arcana-card { max-width: 160px; }
  }

  .arcana-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 400ms cubic-bezier(0.3, 0, 0.3, 1);
  }
  .arcana-card:hover .arcana-inner {
    transform: rotateY(8deg) rotateX(-6deg) scale(1.04);
  }

  .face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
  }

  .frame {
    position: relative;
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, #1a0006 0%, #0A0A0A 60%, #2a0008 100%);
    border: 6px solid #FFD400;
    box-shadow:
      inset 0 0 0 2px #0A0A0A,
      inset 0 0 0 4px #E60012,
      8px 8px 0 #E60012,
      14px 14px 0 #0A0A0A;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 0.6rem;
    overflow: hidden;
  }
  .frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 212, 0, 0.06) 1px, transparent 1px);
    background-size: 8px 8px;
    pointer-events: none;
  }

  .numeral-top,
  .numeral-bottom {
    font-family: 'Anton', 'Impact', serif;
    color: #FFD400;
    font-size: 2.2rem;
    line-height: 1;
    letter-spacing: 0.05em;
    z-index: 2;
  }
  .numeral-bottom {
    transform: rotate(180deg);
    margin-top: auto;
  }

  .symbol-wrap {
    width: 70%;
    margin: 0.5rem auto;
    z-index: 2;
  }
  .symbol-wrap svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .name {
    font-family: 'Anton', 'Impact', sans-serif;
    color: #F5F1E8;
    font-size: 0.95rem;
    letter-spacing: 0.18em;
    text-align: center;
    border-top: 2px solid #E60012;
    border-bottom: 2px solid #E60012;
    padding: 0.3rem 0.5rem;
    margin: 0.4rem 0;
    background: rgba(230, 0, 18, 0.15);
    z-index: 2;
    width: 100%;
  }

  .footer {
    margin-top: 0.6rem;
    text-align: center;
  }
  .dest {
    display: inline-block;
    font-family: 'Anton', 'Impact', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    color: #E60012;
    background: #F5F1E8;
    padding: 0.2rem 0.8rem;
    transform: skewX(-10deg);
    transition: background 160ms, color 160ms, transform 160ms;
  }
  .arcana-card:hover .dest {
    background: #FFD400;
    transform: skewX(-10deg) translateY(-2px);
  }
</style>
