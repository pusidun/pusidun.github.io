---
import Mask from '../shared/Mask.astro';
import VertKana from '../shared/VertKana.astro';
---
<div class="pointer-events-none absolute inset-0 overflow-hidden">
  <!-- Top diagonal red bar with yellow trim -->
  <div
    class="absolute -top-24 -right-40 w-[140%] h-44 bg-p5-red opacity-95"
    style="transform: rotate(-12deg);"
  ></div>
  <div
    class="absolute -top-10 -right-40 w-[140%] h-2 bg-p5-yellow"
    style="transform: rotate(-12deg);"
  ></div>
  <div
    class="absolute -top-6 -right-40 w-[140%] h-[3px] bg-p5-yellow"
    style="transform: rotate(-12deg); opacity: 0.5;"
  ></div>

  <!-- Bottom diagonal red bar -->
  <div
    class="absolute -bottom-24 -left-40 w-[140%] h-36 bg-p5-red opacity-90"
    style="transform: rotate(-12deg);"
  ></div>
  <div
    class="absolute -bottom-10 -left-40 w-[140%] h-[3px] bg-p5-yellow"
    style="transform: rotate(-12deg);"
  ></div>

  <!-- Soft diagonal stripes layer -->
  <div class="absolute inset-0 bg-stripes-soft"></div>

  <!-- High-density halftone -->
  <div class="absolute inset-0 bg-halftone-dense opacity-80"></div>

  <!-- Giant mask silhouette behind content -->
  <Mask
    class="absolute -bottom-32 -left-24 w-[120vmin] text-p5-red/20 hidden sm:block"
    eyeColor="#0A0A0A"
  />

  <!-- Arcana wheel decoration (top-right) -->
  <div
    class="p5-arcana-wheel w-[80vmin] h-[80vmin] -top-[20vmin] -right-[20vmin] hidden lg:block"
  ></div>
  <div
    class="p5-arcana-wheel w-[40vmin] h-[40vmin] -top-[8vmin] -right-[8vmin] hidden lg:block"
    style="animation-direction: reverse; animation-duration: 40s; border-style: dotted;"
  ></div>

  <!-- Top-left avatar badge with P5R phone-message bubble (auto-rotating text) -->
  <a
    href="https://github.com/pusidun"
    target="_blank"
    rel="noopener"
    class="avatar-badge pointer-events-auto"
    aria-label="pusidun on GitHub"
  >
    <span class="avatar-frame">
      <img
        src="https://github.com/pusidun.png?size=200"
        alt=""
        class="avatar-img"
        loading="eager"
        width="80"
        height="80"
      />
    </span>
    <div class="avatar-bubble" aria-live="polite">
      <span class="bubble-text" data-msg-text>Hi 👋 I'm pusidun.</span>
    </div>
  </a>

  <!-- Vertical Japanese kana on left edge -->
  <div class="absolute top-32 left-3 hidden md:block">
    <VertKana text="怪盗団" color="red" />
  </div>
  <!-- Vertical kana on right -->
  <div class="absolute top-32 right-3 hidden md:block">
    <VertKana text="予告状" color="yellow" />
  </div>

  <!-- Tiny scattered stars -->
  <svg
    class="absolute top-1/3 right-[8%] w-6 h-6 text-p5-yellow opacity-70"
    viewBox="0 0 100 100"
    fill="currentColor"
    aria-hidden="true"
  >
    <polygon points="50,0 60,35 100,40 70,60 80,100 50,75 20,100 30,60 0,40 40,35" />
  </svg>
  <svg
    class="absolute bottom-[20%] left-[10%] w-8 h-8 text-p5-red opacity-80"
    viewBox="0 0 100 100"
    fill="currentColor"
    aria-hidden="true"
  >
    <polygon points="50,0 60,35 100,40 70,60 80,100 50,75 20,100 30,60 0,40 40,35" />
  </svg>

  <!-- Huge background "P5" letterform -->
  <div
    class="absolute -bottom-20 right-4 text-[28rem] leading-none p5-headline text-p5-red/10 select-none"
  >
    P5
  </div>
</div>

<style>
  .avatar-badge {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    transform: rotate(-4deg);
    transition: transform 200ms ease-out;
  }
  .avatar-badge:hover {
    transform: rotate(-2deg) scale(1.04);
  }

  .avatar-frame {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--p5-yellow);
    padding: 3px;
    box-shadow:
      0 0 0 3px var(--p5-black),
      4px 4px 0 var(--p5-red),
      4px 4px 0 3px var(--p5-black);
  }
  .avatar-img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--p5-black);
  }

  /* Phone-message bubble (P5R chat-style) */
  .avatar-bubble {
    position: relative;
    background: var(--p5-white);
    border: 2.5px solid var(--p5-black);
    border-radius: 14px;
    padding: 0.4rem 0.75rem 0.45rem;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--p5-black);
    white-space: nowrap;
    box-shadow: 3px 3px 0 var(--p5-red);
    min-width: 140px;
    /* Tiny bobbing motion for "alive" feel */
    animation: bubbleBob 3s ease-in-out infinite;
  }
  @keyframes bubbleBob {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-2px); }
  }

  /* Bubble tail pointing left toward the avatar */
  .avatar-bubble::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 50%;
    width: 12px;
    height: 12px;
    background: var(--p5-white);
    border-left: 2.5px solid var(--p5-black);
    border-bottom: 2.5px solid var(--p5-black);
    transform: translateY(-50%) rotate(45deg);
  }

  /* Text inside bubble — swaps with slide-up + fade between messages */
  .bubble-text {
    display: inline-block;
    transition:
      opacity 260ms ease-out,
      transform 260ms cubic-bezier(0.45, 0, 0.2, 1);
  }
  .bubble-text.is-out {
    opacity: 0;
    transform: translateY(-6px);
  }
  .bubble-text.is-in {
    animation: msgSlideIn 380ms cubic-bezier(0.3, 0, 0.2, 1);
  }
  @keyframes msgSlideIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .avatar-badge {
      top: 0.75rem;
      left: 0.75rem;
      gap: 0.5rem;
    }
    .avatar-frame {
      width: 48px;
      height: 48px;
    }
    .avatar-bubble {
      font-size: 0.65rem;
      padding: 0.3rem 0.55rem 0.35rem;
      min-width: 110px;
    }
  }
</style>

<script>
  // Phone-message bubble: cycle through messages with slide-up animation.
  const MESSAGES = [
    "Hi 👋 I'm pusidun.",
    'Engineer @ LiAuto',
    'C++ · Linux · 分布式',
    'Press ↓ to navigate',
    'Build. Break. Repeat.',
    '予告状 incoming...',
    '怪盗団 codename: 工程师',
    'Hover the menu, Trickster.',
  ];

  const INTERVAL = 3200;
  const OUT_MS = 260;

  const textEl = document.querySelector<HTMLElement>('[data-msg-text]');
  if (textEl) {
    let idx = 0;
    setInterval(() => {
      idx = (idx + 1) % MESSAGES.length;
      textEl.classList.add('is-out');
      textEl.classList.remove('is-in');
      setTimeout(() => {
        textEl.textContent = MESSAGES[idx];
        textEl.classList.remove('is-out');
        textEl.classList.add('is-in');
      }, OUT_MS);
    }, INTERVAL);
  }
</script>
