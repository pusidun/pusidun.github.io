---
// Vertical Japanese decorative text (e.g. 怪盗団 / 予告状) for P5R-style trim.
export interface Props {
  text: string;
  class?: string;
  color?: 'red' | 'yellow' | 'white';
}
const { text, class: className = '', color = 'yellow' } = Astro.props;
const colorClass =
  color === 'red' ? 'text-p5-red' :
  color === 'yellow' ? 'text-p5-yellow' : 'text-p5-white';
---
<div
  class={`vert-kana ${colorClass} ${className}`}
  aria-hidden="true"
>
  {text.split('').map((ch) => (
    <span class="vk-char">{ch}</span>
  ))}
</div>

<style>
  .vert-kana {
    writing-mode: vertical-rl;
    font-family: 'Noto Sans SC', sans-serif;
    font-weight: 900;
    letter-spacing: 0.15em;
    line-height: 1.1;
    font-size: 1.5rem;
    user-select: none;
    pointer-events: none;
  }
  .vk-char {
    display: inline-block;
    transform: rotate(0deg);
  }
</style>
