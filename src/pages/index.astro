---
import BaseLayout from '../layouts/BaseLayout.astro';
import StartScreen from '../components/start/StartScreen.astro';
import ArcanaSection from '../components/start/ArcanaSection.astro';
import LatestPosts from '../components/start/LatestPosts.astro';
---
<BaseLayout
  title="PUSIDUN — Portfolio"
  description="pusidun 的个人站点 · CV · Blog · Projects · About"
>
  <!-- First-paint priority: Hero is the first thing the user sees.
       The Calling Card preloader is rendered inside StartScreen (bottom-right)
       and locks page scroll until it reaches 100%. -->
  <StartScreen />

  <!-- Below-the-fold: static HTML rendered server-side, but their reveal
       animations don't initialize until the preloader fires "preloader:done". -->
  <ArcanaSection />
  <LatestPosts />

  <!-- Footer -->
  <footer class="relative border-t-4 border-p5-red py-8 px-6 sm:px-10 text-center">
    <div class="text-xs font-bold tracking-widest text-p5-white/40">
      © 2026 PUSIDUN ·
      <a href="https://github.com/pusidun" target="_blank" rel="noopener" class="hover:text-p5-yellow transition-colors">GITHUB</a>
    </div>
  </footer>

  <!-- Init GSAP scroll animations as soon as the preloader hits 100%.
       Robust fail-safes ensure animations never stall content visibility. -->
  <script>
    import { initHomeScroll } from '../scripts/scroll-anim';

    let started = false;
    const start = () => {
      if (started) return;
      started = true;
      initHomeScroll();
    };

    window.addEventListener('preloader:done', start, { once: true });

    // Fail-safe 1: window load + grace period in case preloader event never fires
    window.addEventListener('load', () => {
      setTimeout(start, 4500);
    }, { once: true });

    // Fail-safe 2: if the user scrolls before everything else, just initialize now.
    // (Elements are visible by default in CSS, so this is purely to enable
    // any below-fold reveal animations the user hasn't reached yet.)
    const onFirstScroll = () => {
      window.removeEventListener('scroll', onFirstScroll);
      start();
    };
    window.addEventListener('scroll', onFirstScroll, { passive: true, once: true });
  </script>

  <!-- P5R-style keyboard menu navigation: ↑/↓ (or W/S, K/J) move focus, ↵ activates. -->
  <script>
    const menuLinks = Array.from(
      document.querySelectorAll<HTMLElement>('[data-menu-button]'),
    );

    const isPreloading = () =>
      document.documentElement.classList.contains('preloading');
    const isFormField = (el: EventTarget | null) =>
      el instanceof HTMLElement &&
      (el.tagName === 'INPUT' ||
        el.tagName === 'TEXTAREA' ||
        el.isContentEditable);

    window.addEventListener('keydown', (e) => {
      if (isPreloading() || menuLinks.length === 0 || isFormField(e.target)) return;

      const key = e.key.toLowerCase();
      const focused = document.activeElement;
      const currentIdx = menuLinks.indexOf(focused as HTMLElement);

      const focusAt = (i: number) => {
        menuLinks[i].focus({ preventScroll: true });
      };

      switch (key) {
        case 'arrowdown':
        case 's':
        case 'j':
          e.preventDefault();
          focusAt(currentIdx === -1 ? 0 : (currentIdx + 1) % menuLinks.length);
          break;
        case 'arrowup':
        case 'w':
        case 'k':
          e.preventDefault();
          focusAt(
            currentIdx === -1
              ? menuLinks.length - 1
              : (currentIdx - 1 + menuLinks.length) % menuLinks.length,
          );
          break;
        case 'enter':
          // If no menu is focused yet, activate the first one (the default).
          if (currentIdx === -1) {
            e.preventDefault();
            (menuLinks[0] as HTMLAnchorElement).click();
          }
          // Otherwise, the browser activates the focused link by default.
          break;
      }
    });
  </script>
</BaseLayout>
